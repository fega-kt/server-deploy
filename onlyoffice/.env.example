# Port OnlyOffice Document Server lắng nghe trên host (chỉ bind 127.0.0.1)
ONLYOFFICE_PORT=8090

# JWT — bật xác thực, bắt buộc khi server public ra internet
JWT_ENABLED=true
JWT_HEADER=Authorization

# JWT secret — phải trùng với secret dùng ở backend khi ký token
# Sinh chuỗi ngẫu nhiên: openssl rand -hex 32
JWT_SECRET=change_me_to_a_strong_random_secret
