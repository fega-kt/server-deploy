# ────────────────────────────────────────────────
# Mailu — cấu hình chính
# Các giá trị này lưu trong Vault tại secret/mailu
# up.sh fetch từ Vault và ghi ra .env tự động
# ────────────────────────────────────────────────

# Secret key cho session encryption — tạo bằng:
#   openssl rand -hex 16
SECRET_KEY=CHANGE_TO_RANDOM_16_BYTES_HEX

# Subnet nội bộ Docker (không được trùng với các mạng khác trên host)
SUBNET=192.168.203.0/24

# Domain mail chính
DOMAIN=zhizhu.online

# FQDN của mail server — phải khớp với DNS A record và PTR record
HOSTNAMES=mail.zhizhu.online

# Địa chỉ postmaster (nhận undeliverable mail và admin notifications)
POSTMASTER=admin

# ────────────────────────────────────────────────
# TLS
# cert:        cert thủ công — dùng acme.sh + Cloudflare DNS-01 (xem README)
# letsencrypt: HTTP-01 — KHÔNG dùng được vì port 80 bind 127.0.0.1
# notls:       tắt TLS (không dùng production)
# ────────────────────────────────────────────────
TLS_FLAVOR=cert

# ────────────────────────────────────────────────
# Web UI
# WEBMAIL: roundcube hoặc snappymail
# ────────────────────────────────────────────────
ADMIN=true
WEB_ADMIN=/admin
WEB_WEBMAIL=/webmail
WEBMAIL=roundcube

# ────────────────────────────────────────────────
# Rate limiting
# ────────────────────────────────────────────────
AUTH_RATELIMIT_IP=60/hour
AUTH_RATELIMIT_USER=100/day

# ────────────────────────────────────────────────
# Antivirus (clamav image không có tag 2024.06 — để none)
# ────────────────────────────────────────────────
ANTIVIRUS=none

# ────────────────────────────────────────────────
# Logging
# ────────────────────────────────────────────────
LOG_LEVEL=WARNING

# ────────────────────────────────────────────────
# Giới hạn kích thước email (bytes) — 50MB
# ────────────────────────────────────────────────
MESSAGE_SIZE_LIMIT=50000000

# ────────────────────────────────────────────────
# Relay host — gửi outbound mail qua SMTP relay thay vì trực tiếp
# Dùng khi VPS bị block port 25 hoặc muốn dùng SendGrid/SES/...
# Để trống nếu gửi trực tiếp
# ────────────────────────────────────────────────
RELAYHOST=smtp.sendgrid.net:587
RELAYHOST_USERNAME=apikey
RELAYHOST_PASSWORD=CHANGE_TO_SENDGRID_API_KEY

# ────────────────────────────────────────────────
# Misc
# ────────────────────────────────────────────────
DISABLE_STATISTICS=True
