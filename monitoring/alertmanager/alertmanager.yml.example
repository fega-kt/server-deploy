global:
  resolve_timeout: 5m

route:
  group_by: ["alertname"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: "default"
  routes:
    - matchers:
        - severity = critical
      receiver: "critical"

receivers:
  - name: "default"
    # Không gửi gì — chỉ hiện trong Prometheus/Alertmanager UI

  - name: "critical"
    # --- OPTION 1: Email ---
    # email_configs:
    #   - to: "your@email.com"
    #     from: "grafana@yourdomain.com"
    #     smarthost: "smtp.gmail.com:587"
    #     auth_username: "grafana@yourdomain.com"
    #     auth_password: "your_app_password"
    #     require_tls: true

    # --- OPTION 2: Telegram ---
    # webhook_configs:
    #   - url: "https://api.telegram.org/bot<BOT_TOKEN>/sendMessage?chat_id=<CHAT_ID>"
    #     send_resolved: true

inhibit_rules:
  - source_matchers:
      - severity = critical
    target_matchers:
      - severity = warning
    equal: ["alertname"]
